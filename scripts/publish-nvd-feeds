#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

TARGET_FILE="${TARGET_FILE:-merged_nvd_feeds.json.gz}"
CHECKSUM_FILE="${CHECKSUM_FILE:-${TARGET_FILE}.sha256}"
REF_FILE="${REF_FILE:-nvd-feeds.oci-ref}"
ARTIFACT_TYPE="${ARTIFACT_TYPE:-application/vnd.nvd.feeds.v1+json}"
FILE_MEDIA_TYPE="${FILE_MEDIA_TYPE:-application/gzip}"
LOG_PREFIX="${LOG_PREFIX:-publish-nvd-feeds}"

if [ -z "${OCI_REPOSITORY:-}" ] && [ -n "${GITHUB_REPOSITORY:-}" ]; then
    OCI_REPOSITORY="ghcr.io/${GITHUB_REPOSITORY}/nvd-feeds"
fi

export TARGET_FILE CHECKSUM_FILE REF_FILE ARTIFACT_TYPE FILE_MEDIA_TYPE LOG_PREFIX OCI_REPOSITORY

"$SCRIPT_DIR/publish-oci-artifact"
