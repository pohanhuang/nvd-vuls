#!/usr/bin/env bash

set -euo pipefail

TARGET_FILE="${TARGET_FILE:-merged_nvd_feeds.json}"
BUNDLE_FILE="${BUNDLE_FILE:-${TARGET_FILE}.sigstore.json}"
CHECKSUM_FILE="${CHECKSUM_FILE:-${TARGET_FILE}.sha256}"

log() {
    echo "[sign-nvd-feeds] $*"
}

if [ ! -s "$TARGET_FILE" ]; then
    log "Missing target file: $TARGET_FILE"
    exit 1
fi

if ! command -v cosign >/dev/null 2>&1; then
    log "cosign is required"
    exit 1
fi

log "Writing checksum: $CHECKSUM_FILE"
sha256sum "$TARGET_FILE" > "$CHECKSUM_FILE"

log "Writing Sigstore bundle: $BUNDLE_FILE"
cosign sign-blob \
    --yes \
    --bundle "$BUNDLE_FILE" \
    "$TARGET_FILE"

log "BUNDLE_FILE=$BUNDLE_FILE"
log "CHECKSUM_FILE=$CHECKSUM_FILE"
log "Signing complete"
