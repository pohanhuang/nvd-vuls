#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

REF_FILE="${REF_FILE:-nvd-feeds.oci-ref}"
VERIFY_JSON="${VERIFY_JSON:-true}"
EXPECTED_FILE="${EXPECTED_FILE:-merged_nvd_feeds.json.gz}"
VERIFY_JSON_FILE="${VERIFY_JSON_FILE:-merged_nvd_feeds.json.gz}"
LOG_PREFIX="${LOG_PREFIX:-verify-nvd-feeds}"

export REF_FILE VERIFY_JSON EXPECTED_FILE VERIFY_JSON_FILE LOG_PREFIX

"$SCRIPT_DIR/verify-oci-artifact"
