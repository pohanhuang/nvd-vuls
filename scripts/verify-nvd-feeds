#!/usr/bin/env bash

set -euo pipefail

REF_FILE="${REF_FILE:-nvd-feeds.oci-ref}"
CERTIFICATE_OIDC_ISSUER="${CERTIFICATE_OIDC_ISSUER:-https://token.actions.githubusercontent.com}"

log() {
    echo "[verify-nvd-feeds] $*"
}

if [ ! -s "$REF_FILE" ]; then
    log "Missing OCI ref file: $REF_FILE"
    exit 1
fi

if [ -z "${CERTIFICATE_IDENTITY:-}" ]; then
    log "CERTIFICATE_IDENTITY is required"
    exit 1
fi

if ! command -v cosign >/dev/null 2>&1; then
    log "cosign is required"
    exit 1
fi

OCI_REF=$(cat "$REF_FILE")

if [[ "$OCI_REF" != *@sha256:* ]]; then
    log "OCI ref must use a digest: $OCI_REF"
    exit 1
fi

log "Verifying OCI artifact: $OCI_REF"
cosign verify \
    --certificate-oidc-issuer "$CERTIFICATE_OIDC_ISSUER" \
    --certificate-identity "$CERTIFICATE_IDENTITY" \
    "$OCI_REF"

log "Verification complete"
