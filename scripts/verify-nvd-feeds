#!/usr/bin/env bash

set -euo pipefail

TARGET_FILE="${TARGET_FILE:-merged_nvd_feeds.json}"
SIGNATURE_FILE="${SIGNATURE_FILE:-${TARGET_FILE}.asc}"
CHECKSUM_FILE="${CHECKSUM_FILE:-${TARGET_FILE}.sha256}"
PUBLIC_KEY_FILE="${PUBLIC_KEY_FILE:-.github/keys/nvd-signing-public.asc}"

log() {
    echo "[verify-nvd-feeds] $*"
}

if [ ! -s "$TARGET_FILE" ]; then
    log "Missing target file: $TARGET_FILE"
    exit 1
fi

if [ ! -s "$SIGNATURE_FILE" ]; then
    log "Missing signature file: $SIGNATURE_FILE"
    exit 1
fi

if [ ! -s "$CHECKSUM_FILE" ]; then
    log "Missing checksum file: $CHECKSUM_FILE"
    exit 1
fi

GNUPGHOME="$(mktemp -d)"
export GNUPGHOME
trap 'rm -rf "$GNUPGHOME"' EXIT

log "Checking checksum"
sha256sum --check "$CHECKSUM_FILE"

if [ -s "$PUBLIC_KEY_FILE" ]; then
    log "Importing public key from $PUBLIC_KEY_FILE"
    gpg --batch --import "$PUBLIC_KEY_FILE"
elif [ -n "${NVD_SIGNING_PUBLIC_KEY:-}" ]; then
    log "Importing public key from NVD_SIGNING_PUBLIC_KEY"
    printf '%s\n' "$NVD_SIGNING_PUBLIC_KEY" | gpg --batch --import
else
    log "Public key is required. Set NVD_SIGNING_PUBLIC_KEY or add $PUBLIC_KEY_FILE"
    exit 1
fi

log "Verifying detached signature"
gpg --batch --verify "$SIGNATURE_FILE" "$TARGET_FILE"

log "Verification complete"
