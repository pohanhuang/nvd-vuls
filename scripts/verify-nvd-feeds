#!/usr/bin/env bash

set -euo pipefail

TARGET_FILE="${TARGET_FILE:-merged_nvd_feeds.json}"
BUNDLE_FILE="${BUNDLE_FILE:-${TARGET_FILE}.sigstore.json}"
CHECKSUM_FILE="${CHECKSUM_FILE:-${TARGET_FILE}.sha256}"
CERTIFICATE_OIDC_ISSUER="${CERTIFICATE_OIDC_ISSUER:-https://token.actions.githubusercontent.com}"

log() {
    echo "[verify-nvd-feeds] $*"
}

if [ ! -s "$TARGET_FILE" ]; then
    log "Missing target file: $TARGET_FILE"
    exit 1
fi

if [ ! -s "$BUNDLE_FILE" ]; then
    log "Missing Sigstore bundle: $BUNDLE_FILE"
    exit 1
fi

if [ ! -s "$CHECKSUM_FILE" ]; then
    log "Missing checksum file: $CHECKSUM_FILE"
    exit 1
fi

if [ -z "${CERTIFICATE_IDENTITY:-}" ]; then
    log "CERTIFICATE_IDENTITY is required"
    exit 1
fi

if ! command -v cosign >/dev/null 2>&1; then
    log "cosign is required"
    exit 1
fi

log "Checking checksum"
sha256sum --check "$CHECKSUM_FILE"

log "Verifying Sigstore bundle"
cosign verify-blob \
    --bundle "$BUNDLE_FILE" \
    --certificate-oidc-issuer "$CERTIFICATE_OIDC_ISSUER" \
    --certificate-identity "$CERTIFICATE_IDENTITY" \
    "$TARGET_FILE"

log "Verification complete"
