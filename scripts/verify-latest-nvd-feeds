#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

VERIFY_JSON="${VERIFY_JSON:-true}"
EXPECTED_FILE="${EXPECTED_FILE:-merged_nvd_feeds.json}"
VERIFY_JSON_FILE="${VERIFY_JSON_FILE:-merged_nvd_feeds.json}"
LOG_PREFIX="${LOG_PREFIX:-verify-latest-nvd-feeds}"

if [ -z "${OCI_REPOSITORY:-}" ] && [ -n "${GITHUB_REPOSITORY:-}" ]; then
    OCI_REPOSITORY="ghcr.io/${GITHUB_REPOSITORY}/nvd-feeds"
fi

bash "$SCRIPT_DIR/verify-latest-oci-artifact"
